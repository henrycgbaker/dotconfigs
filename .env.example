# dotconfigs instance config — template.
#
# `dotconfigs init` copies this to ~/.dotconfigs/.env (outside the repo, so it is
# never committed); edit that copy. The engine sources it at startup.
#
# Only values that vary per person/machine belong here. Paths dictated by the
# consuming tools (~/.claude, ~/.gitconfig, ~/.config/git) are NOT configurable —
# overriding them would just stop those tools from reading their own config.

# --- Author identity -------------------------------------------------------
# Baked into the {{AUTHOR_NAME}}/{{AUTHOR_EMAIL}} placeholders in settings.json.
# Resolution order: `git config --includes user.{name,email}` → these → a
# built-in default. Leave blank to rely entirely on your git config.
DOTCONFIGS_AUTHOR_NAME=""
DOTCONFIGS_AUTHOR_EMAIL=""

# --- CLI install location --------------------------------------------------
# Where the `dotconfigs` / `dots` symlinks go. Default: ~/.local/bin if it
# exists (on PATH by default on Linux; add it to PATH on macOS), else
# /usr/local/bin. Set this to force a specific dir (e.g. a server's /usr/local/bin
# or Apple-Silicon Homebrew's /opt/homebrew/bin).
# DOTCONFIGS_BIN_DIR="$HOME/.local/bin"
