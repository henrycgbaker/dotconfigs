Examples:
  dotconfigs deploy                      Deploy all groups
  dotconfigs deploy claude               Deploy claude group only
  dotconfigs deploy git                  Deploy git group only
  dotconfigs deploy --force              Deploy all, overwrite conflicts
  dotconfigs deploy --dry-run            Preview all deployments
EOF
            ;;
        status)
            cat <<EOF
dotconfigs status — Check deployment status

Usage:
  dotconfigs status [plugin]

Description:
  Shows deployment status for plugin configuration files.
  Detects drift (broken symlinks, foreign files, wrong targets).
  Without a plugin name, shows status for all plugins.

States:
  ✓  Deployed      Symlink correctly points to dotconfigs
  △  Drifted       Broken symlink, foreign file, or wrong target
  ✗  Not deployed  File doesn't exist

Examples:
  dotconfigs status           Show status of all plugins
  dotconfigs status claude    Show Claude plugin status only
EOF
            ;;
        list)
            cat <<EOF
dotconfigs list — List available plugins

Usage:
  dotconfigs list

Description:
  Lists all available plugins with deployment status.

Example:
  dotconfigs list
EOF
            ;;
        *)
            echo "Error: Unknown command '$command'" >&2
            echo "" >&2
            echo "Available commands: setup, global-init, deploy, project-init, project, cleanup, status, list, help" >&2
            return 1
            ;;
    esac
}

cmd_help() {
    if [[ $# -eq 0 ]]; then
        show_usage
    else
        show_command_help "$1"
    fi
}

cmd_setup() {
    init_colours

    echo ""
    echo "========================================================="
    echo "  dotconfigs - First Time Setup"
    echo "========================================================="
    echo ""

    # Create PATH symlinks (dotconfigs + dots)
    echo "Setting up PATH availability..."
    _create_path_symlink "false" "false"

    echo ""
    echo "Setup complete."
    echo ""
    echo "Next steps:"
    echo "  1. dotconfigs global-init          Scaffold global.json from manifests"
    echo "  2. (optional) Edit .dotconfigs/global.json to customise"
    echo "  3. dotconfigs deploy               Deploy all global config"
    echo "  4. dotconfigs project-init .       Scaffold per-project config"
    echo "  5. dotconfigs project .            Deploy project config"
    echo ""
}

cmd_global_init() {
    if ! command -v jq &>/dev/null; then
        echo "Error: jq is required but not installed." >&2
        exit 1
    fi

    local force="false"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force="true"; shift ;;
            *) echo "Error: Unknown option '$1'" >&2; exit 1 ;;
        esac
    done

    local json
    json=$(assemble_from_manifests "global")

    if ! write_with_overwrite_protection "$GLOBAL_CONFIG" "$json" "$force"; then
        return 0
    fi

    echo ""
    echo "Next steps:"
    echo "  1. (optional) Edit .dotconfigs/global.json to customise"
    echo "  2. dotconfigs deploy              Deploy all global config"
}

# Ask a yes/no question with default
# Args: prompt_text, default (y/n)
# Returns: 0 for yes, 1 for no
wizard_yesno() {
    local prompt_text="$1"
    local default="$2"
    local user_input
    local default_hint

    if [[ "$default" == "y" ]]; then
        default_hint="Y/n"
    else
        default_hint="y/N"
    fi

    read -p "$prompt_text [$default_hint]: " user_input
    user_input="${user_input:-$default}"

    user_input=$(echo "$user_input" | tr '[:upper:]' '[:lower:]')
    case "$user_input" in
        y|yes) return 0 ;;
        n|no) return 1 ;;
        *)
            echo "Invalid input. Please enter y or n." >&2
            wizard_yesno "$prompt_text" "$default"
            ;;
    esac
}

_create_path_symlink() {
    local dry_run="$1"
    local force_mode="$2"

    # Determine symlink target: prefer ~/.local/bin, fall back to /usr/local/bin
    local target=""
    if [[ -d "$HOME/.local/bin" ]]; then
        target="$HOME/.local/bin/dotconfigs"
    elif [[ -d "/usr/local/bin" ]]; then
        target="/usr/local/bin/dotconfigs"
    else
        # Neither exists, try to create ~/.local/bin
        if mkdir -p "$HOME/.local/bin" 2>/dev/null; then
            target="$HOME/.local/bin/dotconfigs"
        else
            echo "Warning: Cannot create ~/.local/bin and /usr/local/bin not found" >&2
            echo "To make dotconfigs available on PATH, add to your shell profile:" >&2
            echo "  export PATH=\"$SCRIPT_DIR:\$PATH\"" >&2
            return 0
        fi
    fi

    # Dry-run mode
    if [[ "$dry_run" == "true" ]]; then
        if [[ -L "$target" ]] && [[ "$(readlink "$target")" == "$SCRIPT_DIR/dotconfigs" ]]; then
            echo "CLI availability:"
            echo "  Unchanged: $target → $SCRIPT_DIR/dotconfigs"
            local dots_target="$(dirname "$target")/dots"
            if [[ -L "$dots_target" ]] && [[ "$(readlink "$dots_target")" == "$SCRIPT_DIR/dotconfigs" ]]; then
                echo "  Unchanged: $dots_target → $SCRIPT_DIR/dotconfigs"
            else
                echo "  Would create: $dots_target → $SCRIPT_DIR/dotconfigs"
            fi
        else
            echo "CLI availability:"
            echo "  Would create: $target → $SCRIPT_DIR/dotconfigs"
            echo "  Would create: $(dirname "$target")/dots → $SCRIPT_DIR/dotconfigs"
        fi
        return 0
    fi

    # Create or verify both symlinks (dotconfigs + dots)
    local symlinks_to_check=("$target" "$(dirname "$target")/dots")
    local symlink_names=("dotconfigs" "dots")

    for i in 0 1; do
        local sym="${symlinks_to_check[$i]}"
        local name="${symlink_names[$i]}"

        if [[ -L "$sym" ]]; then
            local current=$(readlink "$sym")
            if [[ "$current" == "$SCRIPT_DIR/dotconfigs" ]]; then
                echo "$name already on PATH (symlink correct)"
                continue
            else
                # Symlink exists but points elsewhere
                if [[ "$force_mode" != "true" ]]; then
                    echo "Warning: $name symlink exists but points to: $current" >&2
                    wizard_yesno "Overwrite with dotconfigs symlink?" "n" || continue
                fi
            fi
        elif [[ -e "$sym" ]]; then
            echo "Warning: File exists at $sym (not a symlink)" >&2
            continue
        fi

        # Create symlink
        if ln -sf "$SCRIPT_DIR/dotconfigs" "$sym" 2>/dev/null; then
            echo "$name added to PATH: $sym"
        else
            echo "Warning: Failed to create $name symlink at $sym" >&2
        fi
    done
}

cmd_undeploy() {
    local dry_run="true"
    local config_file="$GLOBAL_CONFIG"
    local project_path=""
    local group=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --apply)   dry_run="false"; shift ;;
            --dry-run) dry_run="true"; shift ;;
            --project)
                shift
                project_path="${1:-.}"
                shift
                ;;
            -*)
                echo "Error: Unknown option '$1'" >&2
                echo "Usage: dotconfigs undeploy [group] [--apply] [--dry-run] [--project <path>]" >&2
                exit 1
                ;;
            *)
                if [[ -z "$group" ]]; then
                    group="$1"
                fi
                shift
                ;;
        esac
    done

    if [[ -n "$project_path" ]]; then
        project_path=$(expand_path "$project_path")
        config_file="$project_path/.dotconfigs/project.json"
    fi

    if ! check_jq; then
        return 1
    fi
    if [[ ! -f "$config_file" ]]; then
        echo "Error: config file not found: $config_file" >&2
        exit 1
    fi

    undeploy_from_json "$config_file" "$SCRIPT_DIR" "$group" "$dry_run" "$project_path"

    if [[ "$dry_run" == "true" && "${removed:-0}" -gt 0 ]]; then
        echo ""
        echo "Run 'dotconfigs undeploy --apply' to remove."
    fi
}

cmd_cleanup() {
    local dry_run="true"
    local config_file="$GLOBAL_CONFIG"
    local project_path=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --apply)
                dry_run="false"
                shift
                ;;
            --dry-run)
                dry_run="true"
                shift
                ;;
            --project)
                shift
                project_path="${1:-.}"
                shift
                ;;
            -*)
                echo "Error: Unknown option '$1'" >&2
                echo "Usage: dotconfigs cleanup [--apply] [--dry-run] [--project <path>]" >&2
                exit 1
                ;;
            *)
                shift
                ;;
        esac
    done

    # Resolve project config if --project given
    if [[ -n "$project_path" ]]; then
        project_path=$(expand_path "$project_path")
        config_file="$project_path/.dotconfigs/project.json"
    fi

    # Check jq + config exist
    if ! check_jq; then
        return 1
    fi
    if [[ ! -f "$config_file" ]]; then
        echo "Error: config file not found: $config_file" >&2
        exit 1
    fi

    init_colours

    if [[ "$dry_run" == "true" ]]; then
        echo "Cleanup dry-run (use --apply to remove):"
    else
        echo "Cleaning up stale symlinks:"
    fi
    echo ""

    removed=0

    # Parse all modules and run cleanup on each target directory
    local modules_data
    modules_data=$(parse_modules "$config_file")

    if [[ -z "$modules_data" ]]; then
        echo "No modules found."
        return 0
    fi

    while IFS=$'\t' read -r source target method include_csv; do
        local abs_target
        abs_target=$(expand_tilde "$target")

        # If project, resolve relative targets
        if [[ -n "$project_path" && "$abs_target" != /* ]]; then
            abs_target="$project_path/$abs_target"
        fi

        local abs_source
        if [[ "$source" != /* ]]; then
            abs_source="$SCRIPT_DIR/$source"
        else
            abs_source="$source"
        fi

        case "$method" in
            symlink)
                if [[ -d "$abs_source" ]]; then
                    # Directory module: build expected CSV from include list or source dir
                    local deployed_csv=""
                    if [[ "$include_csv" == "__NONE__" ]]; then
                        deployed_csv=""
                    elif [[ -n "$include_csv" ]]; then
                        deployed_csv="$include_csv"
                    else
                        # No include list — all source files are expected
                        for file in "$abs_source"/*; do
                            [[ ! -e "$file" ]] && continue
                            [[ -d "$file" ]] && continue
                            if [[ -n "$deployed_csv" ]]; then
                                deployed_csv="$deployed_csv,$(basename "$file")"
                            else
                                deployed_csv="$(basename "$file")"
                            fi
                        done
                    fi
                    cleanup_stale_in_directory "$abs_target" "$deployed_csv" "$SCRIPT_DIR" "$dry_run"
                else
                    # Single-file symlink: check if target is broken
                    if [[ -L "$abs_target" && ! -e "$abs_target" ]]; then
                        if [[ "$dry_run" == "true" ]]; then
                            echo "  Would remove broken symlink: $abs_target"
                        else
                            rm -f "$abs_target"
                            echo "  ✓ Removed broken symlink: $abs_target"
                        fi
                        removed=$(( removed + 1 ))
                    fi
                fi
                ;;
        esac
    done <<< "$modules_data"

    echo ""
    echo "Cleanup summary:"
    echo "  Removed: $removed"
    if [[ "$dry_run" == "true" && "$removed" -gt 0 ]]; then
        echo ""
        echo "Run 'dotconfigs cleanup --apply' to remove."
    fi
}

cmd_deploy() {
    local group=""
    local dry_run=false
    local force_mode=false

    # Parse arguments: extract group name and flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                dry_run=true
                shift
                ;;
            --force)
                force_mode=true
                shift
                ;;
            -*)
                echo "Error: Unknown option '$1'" >&2
                exit 1
                ;;
            *)
                # First non-flag argument is the group name
                if [[ -z "$group" ]]; then
                    group="$1"
                fi
                shift
                ;;
        esac
    done

    # Initialize colours for dry-run header
    if [[ "$dry_run" == "true" ]]; then
        init_colours
        echo "$(colour_cyan "═══════════════════════════════════════════════════════════")"
        echo "$(colour_cyan "  DRY RUN - No changes will be made")"
        echo "$(colour_cyan "═══════════════════════════════════════════════════════════")"
        echo ""
    fi

    # Deploy from global.json
    deploy_from_json "$GLOBAL_CONFIG" "$SCRIPT_DIR" "$group" "$dry_run" "$force_mode"

    # Reconcile git hook seeding (init.templateDir) with the selection.
    _reconcile_git_templatedir "$dry_run"

    # Create PATH symlink (after all deploys)
    echo ""
    _create_path_symlink "$dry_run" "$force_mode"
}

# Couple init.templateDir to the git `hooks` module so new repos seed hooks iff
# that module is selected. Set it in ~/.gitconfig when `hooks` is in global.json,
# unset it (only if it is still our value) when it is excluded — so disabling git
# seeding is just removing `hooks` from the selection, with no orphan config.
_reconcile_git_templatedir() {
    local dry_run="${1:-false}"
    command -v git >/dev/null 2>&1 || return 0
    [[ -f "$GLOBAL_CONFIG" ]] || return 0

    local ours="~/.dotconfigs/git-template"
    local ours_abs; ours_abs=$(expand_tilde "$ours")
    local hooks_selected="false"
    if jq -e '.git.hooks' "$GLOBAL_CONFIG" >/dev/null 2>&1; then
        hooks_selected="true"
    fi
    # `|| true`: git config --get exits 1 when unset, which would trip `set -e`.
    local current; current=$(git config --global --get init.templateDir 2>/dev/null || true)

    if [[ "$hooks_selected" == "true" ]]; then
        [[ "$current" == "$ours" || "$current" == "$ours_abs" ]] && return 0
        if [[ "$dry_run" == "true" ]]; then
            echo "  Would set init.templateDir → $ours (git hook seeding)"
        else
            git config --global init.templateDir "$ours"
            echo "  Set init.templateDir → $ours (git hook seeding enabled)"
        fi
    else
        # Only clear OUR value; never clobber a templateDir the user set themselves.
        [[ "$current" == "$ours" || "$current" == "$ours_abs" ]] || return 0
        if [[ "$dry_run" == "true" ]]; then
            echo "  Would unset init.templateDir (git hooks module not selected)"
        else
            git config --global --unset init.templateDir || true
            echo "  Unset init.templateDir (git hooks module not selected → no seeding)"
        fi
    fi
}

cmd_status() {
    local plugin_filter="${1:-}"

    init_colours
    check_jq || return 1
    _require_global_config || return 1

    if [[ -n "$plugin_filter" ]] && ! plugin_exists "$plugin_filter"; then
        echo "Error: Plugin '$plugin_filter' not found" >&2
        list_available_plugins
        return 1
    fi

    local plugin lines has_ok has_drift has_missing count_ok total
    while IFS= read -r plugin; do
        [[ -n "$plugin_filter" && "$plugin" != "$plugin_filter" ]] && continue

        lines=$(_collect_plugin_states "$plugin")
        if [[ -z "$lines" ]]; then
            printf "%b %s\n\n" "$(colour_yellow "$plugin")" "no modules in $GLOBAL_CONFIG"
            continue
        fi

        _tally_states "$lines" has_ok has_drift has_missing count_ok total

        if [[ "$has_drift" == "true" ]]; then
            printf "%b %b %s\n" "$(colour_yellow "$plugin")" "$(colour_yellow "$SYMBOL_DRIFT")" "deployed (drift detected)"
        elif [[ "$has_missing" == "true" && "$has_ok" != "true" ]]; then
            printf "%b %b %s\n" "$(colour_red "$plugin")" "$(colour_red "$SYMBOL_MISSING")" "not deployed"
        elif [[ "$has_missing" == "true" ]]; then
            printf "%b %b %s (%d/%d)\n" "$(colour_yellow "$plugin")" "$(colour_yellow "$SYMBOL_DRIFT")" "partially deployed" "$count_ok" "$total"
        else
            printf "%b %b %s\n" "$(colour_green "$plugin")" "$(colour_green "$SYMBOL_OK")" "deployed"
        fi

        local state name
        while IFS=$'\t' read -r state name; do
            [[ -z "$state" ]] && continue
            _print_file_status "$name" "$state"
        done <<< "$lines"

        echo ""
    done < <(discover_plugins "$PLUGINS_DIR")

    # Project git-hook drift audit: git hooks live per-repo in .git/hooks and are
    # easily lost (re-clone, .git wipe). Walk the registry of project-deployed
    # repos and flag any whose dotconfigs git hooks are missing or dangling.
    if [[ -z "$plugin_filter" || "$plugin_filter" == "git" ]]; then
        _audit_project_hooks
    fi
}

# Audit every registered repo's git hooks against the git plugin's project
# include list. Prints a per-repo OK/missing/dangling summary. Repos that no
# longer exist are reported as gone (registry left intact — the user prunes).
_audit_project_hooks() {
    [[ -f "$PROJECT_REGISTRY" ]] || return 0

    local expected
    expected=$(jq -r '.project.hooks.include[]?' "$PLUGINS_DIR/git/manifest.json" 2>/dev/null)
    [[ -z "$expected" ]] && return 0

    printf "%b\n" "$(colour_cyan 'project git-hook audit')"

    local repo hookdir name target problems
    while IFS= read -r repo; do
        [[ -z "$repo" ]] && continue
        if [[ ! -d "$repo/.git" ]]; then
            printf "  %b %s %s\n" "$(colour_yellow "$SYMBOL_DRIFT")" "$repo" "(gone — no .git)"
            continue
        fi
        hookdir="$repo/.git/hooks"
        problems=""
        while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            target="$hookdir/$name"
            if [[ ! -e "$target" ]]; then
                # -e follows symlinks: a dangling symlink is also caught here.
                if [[ -L "$target" ]]; then
                    problems="$problems dangling:$name"
                else
                    problems="$problems missing:$name"
                fi
            fi
        done <<< "$expected"

        if [[ -z "$problems" ]]; then
            printf "  %b %s\n" "$(colour_green "$SYMBOL_OK")" "$repo"
        else
            printf "  %b %s%b\n" "$(colour_red "$SYMBOL_MISSING")" "$repo" ""
            local p
            for p in $problems; do
                printf "      %b %s\n" "$(colour_red "${p%%:*}")" "${p#*:}"
            done
            printf "      %bfix: dotconfigs project-deploy %s%b\n" "${COLOUR_YELLOW:-}" "$repo" "${COLOUR_RESET:-}"
        fi
    done < "$PROJECT_REGISTRY"
    echo ""
}

cmd_list() {
    init_colours
    check_jq || return 1
    _require_global_config || return 1

    echo "Available plugins:"
    echo ""

    local plugin lines has_ok has_drift has_missing count_ok total
    while IFS= read -r plugin; do
        lines=$(_collect_plugin_states "$plugin")
        if [[ -z "$lines" ]]; then
            printf "  - %s (no modules in global.json)\n" "$plugin"
            continue
        fi

        _tally_states "$lines" has_ok has_drift has_missing count_ok total

        if [[ "$has_drift" == "true" ]]; then
            printf "  %b %s drifted (%d/%d ok)\n" "$(colour_yellow "$SYMBOL_DRIFT")" "$plugin" "$count_ok" "$total"
        elif [[ "$has_missing" == "true" && "$has_ok" != "true" ]]; then
            printf "  %b %s not deployed\n" "$(colour_red "$SYMBOL_MISSING")" "$plugin"
        elif [[ "$has_missing" == "true" ]]; then
            printf "  %b %s partially deployed (%d/%d)\n" "$(colour_yellow "$SYMBOL_DRIFT")" "$plugin" "$count_ok" "$total"
        else
            printf "  %b %s deployed\n" "$(colour_green "$SYMBOL_OK")" "$plugin"
        fi
    done < <(discover_plugins "$PLUGINS_DIR")
}

# Lint plugin manifests and scan deployed settings for dangling references.
# Standalone: never deploys, never mutates. Exits non-zero if any manifest is
# malformed or points at a missing source. Dangling deployed references are
# reported as warnings (exit stays zero) unless --strict is passed.
cmd_validate() {
    init_colours
    check_jq || return 1

    local strict="false"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --strict) strict="true"; shift ;;
            *) echo "Error: Unknown option '$1'" >&2; exit 1 ;;
        esac
    done

    # Allowed module methods and keys (manifest schema whitelist).
    local valid_methods="symlink copy merge append managed"
    errors=0
    warnings=0

    local plugin_dir plugin manifest
    for plugin_dir in "$PLUGINS_DIR"/*/; do
        [[ -d "$plugin_dir" ]] || continue
        plugin=$(basename "$plugin_dir")
        manifest="$plugin_dir/manifest.json"

        if [[ ! -f "$manifest" ]]; then
            printf "  %b✗ %s: no manifest.json%b\n" "${COLOUR_RED:-}" "$plugin" "${COLOUR_RESET:-}"
            errors=$(( errors + 1 ))
            continue
        fi
        if ! jq empty "$manifest" 2>/dev/null; then
            printf "  %b✗ %s: manifest.json is not valid JSON%b\n" "${COLOUR_RED:-}" "$plugin" "${COLOUR_RESET:-}"
            errors=$(( errors + 1 ))
            continue
        fi

        # Each module: validate method, key whitelist, and source existence.
        local module_errors=0
        local rows
        rows=$(jq -r '
            (.global // {}), (.project // {})
            | to_entries[]
            | select(.value | type == "object" and has("source"))
            | [ .key, .value.source, (.value.method // ""),
                ((.value | keys) - ["source","target","method","include","exclude"] | join(",")) ]
            | @tsv
        ' "$manifest" 2>/dev/null)

        local mod_key src method extra_keys abs_src
        while IFS=$'\t' read -r mod_key src method extra_keys; do
            [[ -z "$mod_key" ]] && continue
            if [[ " $valid_methods " != *" $method "* ]]; then
                printf "  %b✗ %s/%s: invalid method '%s'%b\n" "${COLOUR_RED:-}" "$plugin" "$mod_key" "$method" "${COLOUR_RESET:-}"
                errors=$(( errors + 1 )); module_errors=$(( module_errors + 1 ))
            fi
            if [[ -n "$extra_keys" ]]; then
                printf "  %b✗ %s/%s: unknown manifest key(s): %s%b\n" "${COLOUR_RED:-}" "$plugin" "$mod_key" "$extra_keys" "${COLOUR_RESET:-}"
                errors=$(( errors + 1 )); module_errors=$(( module_errors + 1 ))
            fi
            if [[ "$src" != /* ]]; then abs_src="$SCRIPT_DIR/$src"; else abs_src="$src"; fi
            if [[ ! -e "$abs_src" ]]; then
                printf "  %b✗ %s/%s: source not found: %s%b\n" "${COLOUR_RED:-}" "$plugin" "$mod_key" "$src" "${COLOUR_RESET:-}"
                errors=$(( errors + 1 )); module_errors=$(( module_errors + 1 ))
            fi
        done <<< "$rows"

        if [[ "$module_errors" -eq 0 ]]; then
            printf "  %b✓ %s: manifest OK%b\n" "${COLOUR_GREEN:-}" "$plugin" "${COLOUR_RESET:-}"
        fi
    done

    # Scan deployed merge-method JSON targets for dangling command references.
    if [[ -f "$GLOBAL_CONFIG" ]]; then
        _refcheck_merge_targets "$(parse_modules "$GLOBAL_CONFIG" "")"
    fi

    # Defensive: flag claude hooks wired in BOTH the global and the current
    # project's settings.json (additive merge → double-fire). Only fires when a
    # project .claude/settings.json exists in the CWD.
    if declare -f refcheck_hook_duplication >/dev/null 2>&1; then
        refcheck_hook_duplication \
            "$HOME/.claude/settings.json" \
            "$PWD/.claude/settings.json" || true
    fi

    # Flag plugin hooks declared in BOTH global.json and the current project.json
    # (same hook listed under `.<plugin>.hooks.include` in both). One consolidated
    # warning per plugin pointing at both files.
    if declare -f refcheck_hook_manifest_overlap >/dev/null 2>&1 \
       && [[ -f "$PWD/.dotconfigs/project.json" ]]; then
        refcheck_hook_manifest_overlap "git" \
            "$GLOBAL_CONFIG" "$PWD/.dotconfigs/project.json" || true
        refcheck_hook_manifest_overlap "claude" \
            "$GLOBAL_CONFIG" "$PWD/.dotconfigs/project.json" || true
    fi

    echo ""
    if [[ "$errors" -gt 0 ]]; then
        printf "%b✗ validate: %s error(s), %s warning(s)%b\n" "${COLOUR_RED:-}" "$errors" "$warnings" "${COLOUR_RESET:-}" >&2
        return 1
    fi
    if [[ "$warnings" -gt 0 ]]; then
        printf "%b△ validate: 0 errors, %s warning(s)%b\n" "${COLOUR_YELLOW:-}" "$warnings" "${COLOUR_RESET:-}"
        [[ "$strict" == "true" ]] && return 1
        return 0
    fi
    printf "%b✓ validate: all manifests and deployed references OK%b\n" "${COLOUR_GREEN:-}" "${COLOUR_RESET:-}"
    return 0
}

cmd_project() {
    # Space-form subcommands: `project init [path]` aliases `project-init [path]`;
    # `project deploy [path]` is just `project [path]` with a redundant verb.
    if [[ "${1:-}" == "init" ]]; then
        shift
        cmd_project_init "$@"
        return
    fi
    if [[ "${1:-}" == "deploy" ]]; then
        shift
    fi

    local project_path=""
    local dry_run="false"
    local force="false"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                dry_run="true"
                shift
                ;;
            --force)
                force="true"
                shift
                ;;
            -*)
                echo "Error: Unknown option '$1'" >&2
                echo "Usage: dotconfigs project [path] [--dry-run] [--force]" >&2
                exit 1
                ;;
            *)
                if [[ -z "$project_path" ]]; then
                    project_path="$1"
                    shift
                else
                    echo "Error: Multiple paths specified" >&2
                    exit 1
                fi
                ;;
        esac
    done

    # Default to CWD if no path specified
    if [[ -z "$project_path" ]]; then
        project_path="$PWD"
    fi

    # Resolve to absolute path
    project_path=$(expand_path "$project_path")
    if [[ $? -ne 0 ]]; then
        echo "Error: Invalid path: $project_path" >&2
        exit 1
    fi

    # Validate git repo
    if ! validate_git_repo "$project_path"; then
        echo "Error: Not a git repository: $project_path" >&2
        echo "Initialize with: git init" >&2
        exit 1
    fi

    # Check for project.json
    local config_file="$project_path/.dotconfigs/project.json"
    if [[ ! -f "$config_file" ]]; then
        echo "Error: No .dotconfigs/project.json found at $project_path" >&2
        echo "Run: dotconfigs project-init $project_path" >&2
        exit 1
    fi

    # Deploy from JSON
    deploy_from_json "$config_file" "$SCRIPT_DIR" "" "$dry_run" "$force" "$project_path"

    # Auto-exclude .dotconfigs/ in .git/info/exclude (unless dry-run)
    if [[ "$dry_run" != "true" ]]; then
        local exclude_file="$project_path/.git/info/exclude"
        if ! grep -qxF ".dotconfigs/" "$exclude_file" 2>/dev/null; then
            mkdir -p "$(dirname "$exclude_file")"
            echo ".dotconfigs/" >> "$exclude_file"
            echo ""
            echo "Added .dotconfigs/ to .git/info/exclude"
        fi

        # Defensive: if this project wires claude hooks in its own settings.json,
        # warn about any that also fire globally (additive merge → double-fire).
        if declare -f refcheck_hook_duplication >/dev/null 2>&1; then
            refcheck_hook_duplication \
                "$HOME/.claude/settings.json" \
                "$project_path/.claude/settings.json" || true
        fi

        # Register this repo so `dotconfigs status` can later audit its git hooks
        # for drift (a project's hooks live in .git/hooks and are easy to lose to
        # a re-clone or a `.git` reset). Idempotent — one absolute path per line.
        _register_project "$project_path"
    fi
}

# Append a repo path to the project registry (deduplicated). Canonicalises to an
# absolute path so the status audit can resolve it from any cwd. Args: path
_register_project() {
    local path="$1"
    # Absolutise: expand_path only handles ~, so a relative "." would be stored
    # verbatim and break the audit. cd into the repo and read its real path.
    path=$(cd "$path" 2>/dev/null && pwd -P) || return 0
    mkdir -p "$(dirname "$PROJECT_REGISTRY")"
    if ! grep -qxF "$path" "$PROJECT_REGISTRY" 2>/dev/null; then
        echo "$path" >> "$PROJECT_REGISTRY"
    fi
}

cmd_project_init() {
    local project_path=""

    # Parse argument
    if [[ $# -eq 0 ]]; then
        # Check if CWD is the dotconfigs repo itself
        if [[ "$(pwd)" -ef "$SCRIPT_DIR" ]]; then
            echo "Error: Cannot use dotconfigs repo as project target" >&2
            echo "Run from a project directory, or specify a path: dotconfigs project-init /path/to/project" >&2
            exit 1
        fi

        # Check if CWD is a git repo
        if ! git -C "$PWD" rev-parse --git-dir >/dev/null 2>&1; then
            echo "Error: Current directory is not a git repository" >&2
            echo "Run from a git repo, or specify a path: dotconfigs project-init /path/to/project" >&2
            exit 1
        fi

        # Use CWD
        project_path="$PWD"
    else
        project_path="$1"
        shift
    fi

    # Resolve to absolute path
    project_path=$(expand_path "$project_path")
    if [[ $? -ne 0 ]]; then
        echo "Error: Invalid path: $project_path" >&2
        exit 1
    fi

    # Validate git repo
    if ! validate_git_repo "$project_path"; then
        echo "Error: Not a git repository: $project_path" >&2
        echo "Initialize with: git init" >&2
        exit 1
    fi

    if ! command -v jq &>/dev/null; then
        echo "Error: jq is required but not installed." >&2
        echo "Install with: brew install jq" >&2
        exit 1
    fi

    local config_file="$project_path/.dotconfigs/project.json"
    local json
    json=$(assemble_from_manifests "project")

    if ! write_with_overwrite_protection "$config_file" "$json"; then
        return 0
    fi

    # Auto-exclude .dotconfigs/ in .git/info/exclude
    local exclude_file="$project_path/.git/info/exclude"
    if ! grep -qxF ".dotconfigs/" "$exclude_file" 2>/dev/null; then
        mkdir -p "$(dirname "$exclude_file")"
        echo ".dotconfigs/" >> "$exclude_file"
        echo "Added .dotconfigs/ to .git/info/exclude"
    fi

    echo ""
    echo "Next steps:"
    echo "  1. Edit $config_file"
    echo "  2. Run: dotconfigs project          (from the project directory)"
}

main() {
    if [[ $# -eq 0 ]]; then
        show_usage
        exit 0
    fi

    case "$1" in
        setup)
            cmd_setup
            ;;
        global-init)
            cmd_global_init "${@:2}"
            ;;
        project-init)
            cmd_project_init "${@:2}"
            ;;
        project-deploy|project)
            cmd_project "${@:2}"
            ;;
        cleanup)
            cmd_cleanup "${@:2}"
            ;;
        undeploy)
            cmd_undeploy "${@:2}"
            ;;
        global-deploy|deploy)
            cmd_deploy "${@:2}"
            ;;
        status)
            cmd_status "${@:2}"
            ;;
        validate)
            cmd_validate "${@:2}"
            ;;
        list)
            cmd_list
            ;;
        help)
            cmd_help "${@:2}"
            ;;
        --help|-h)
            show_usage
            exit 0
            ;;
        *)
            echo "Error: Unknown command '$1'" >&2
            echo "" >&2
            show_usage
            exit 1
            ;;
    esac
}

main "$@"
