#!/bin/bash
# dotconfigs — Unified configuration management CLI entry point

set -e

# Resolve symlinks to find real script location (bash 3.2 compatible)
_source="${BASH_SOURCE[0]}"
while [[ -L "$_source" ]]; do
    _dir="$(cd "$(dirname "$_source")" && pwd)"
    _source="$(readlink "$_source")"
    [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_source")" && pwd)"
unset _source _dir
PLUGINS_DIR="$SCRIPT_DIR/plugins"
# Assembled global selection. Override for tests (DOTCONFIGS_GLOBAL_CONFIG).
GLOBAL_CONFIG="${DOTCONFIGS_GLOBAL_CONFIG:-$SCRIPT_DIR/.dotconfigs/global.json}"
# Registry of repos that have had `project-deploy` run, so `status` can audit
# their git hooks for drift (missing/dangling) after the fact. Override for tests.
PROJECT_REGISTRY="${DOTCONFIGS_PROJECT_REGISTRY:-$HOME/.dotconfigs/projects.list}"

# Source shared libraries eagerly (small files)
source "$SCRIPT_DIR/lib/symlinks.sh"
source "$SCRIPT_DIR/lib/discovery.sh"
source "$SCRIPT_DIR/lib/validation.sh"
source "$SCRIPT_DIR/lib/colours.sh"
source "$SCRIPT_DIR/lib/deploy.sh"
source "$SCRIPT_DIR/lib/refcheck.sh"
source "$SCRIPT_DIR/lib/init.sh"

