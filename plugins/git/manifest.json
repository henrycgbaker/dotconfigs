{
  "global": {
    "hooks": {
      "source": "plugins/git/hooks",
      "target": "~/.dotconfigs/git-hooks",
      "method": "symlink",
      "include": ["commit-msg", "post-checkout", "post-merge", "post-rewrite", "pre-commit", "pre-push", "pre-rebase", "prepare-commit-msg"]
    },
    "config-base": {
      "source": "plugins/git/templates/gitconfig",
      "target": "~/.dotconfigs/gitconfig-base",
      "method": "symlink"
    },
    "config-include": {
      "source": "plugins/git/templates/gitconfig-include",
      "target": "~/.gitconfig",
      "method": "append"
    },
    "global-excludes": {
      "source": "plugins/git/templates/global-excludes",
      "target": "~/.config/git/ignore",
      "method": "symlink"
    }
  },
  "project": {
    "hooks": { 
      "source": "plugins/git/hooks",
      "target": ".git/hooks",
      "method": "symlink",
      "include": ["commit-msg", "post-checkout", "post-merge", "post-rewrite", "pre-commit", "pre-push", "pre-rebase", "prepare-commit-msg"],
      "exclude": [] 
    },
    "project-excludes": {
      "source": "plugins/git/templates/project-excludes",
      "target": ".git/info/exclude",
      "method": "append"
    },
    "gitignore": {
      "source": "plugins/git/templates/gitignore-default",
      "target": ".gitignore",
      "method": "append"
    }
  }
}
