#!/usr/bin/env bash
# === METADATA ===
# NAME: commit-msg
# TYPE: git-hook
# PLUGIN: git
# DESCRIPTION: Blocks AI attribution patterns in commit messages
# CONFIGURABLE: per-check via git config dotconfigs.commit-msg.<check> (block-ai-attribution)
# ================

# No `set -e`: each check owns its exit explicitly (see pre-commit).
HOOK="commit-msg"
_check_on() {
    local v; v=$(git config --bool "dotconfigs.$HOOK.$1" 2>/dev/null)
    [[ "$v" != false ]]
}
_block() {
    echo "❌ BLOCKED by $HOOK/$1: $2" >&2
    echo "   to temporarily disable this check (NOT-recommended, requires explicit user opt-in): set \`git.hooks.$HOOK.checks.$1=false\` in \`~/.dotconfigs/deploy.json\`, then: \`dotconfigs deploy\`" >&2
    exit 1
}

COMMIT_MSG_FILE=$1

# --- block-ai-attribution: reject AI attribution in the commit message ---
if _check_on block-ai-attribution; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    AI_PATTERNS=(
        "Co-Authored-By:.*Claude"
        "Co-Authored-By:.*GPT"
        "Co-Authored-By:.*AI"
        "Generated by Claude"
        "Generated by GPT"
        "Generated with Claude"
        "Generated with GPT"
        "🤖.*Generated"
        "Written by AI"
        "AI-assisted"
    )
    for pattern in "${AI_PATTERNS[@]}"; do
        if echo "$COMMIT_MSG" | grep -qiE "$pattern"; then
            _block block-ai-attribution "commit message contains AI attribution (pattern: $pattern)"
        fi
    done
fi

# Source project-specific commit-msg if it exists
if [ -x .git/hooks/commit-msg.local ]; then
    .git/hooks/commit-msg.local "$COMMIT_MSG_FILE"
fi

exit 0
