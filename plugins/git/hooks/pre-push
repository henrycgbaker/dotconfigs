#!/usr/bin/env bash
# === METADATA ===
# NAME: pre-push
# TYPE: git-hook
# PLUGIN: git
# DESCRIPTION: Force-push protection and fast lint/format check (tests + types run in CI)
# CONFIGURABLE: per-check via git config dotconfigs.pre-push.<check> (force-push-guard, ruff)
# ================

# No `set -e`: each check owns its exit explicitly (see pre-commit).
HOOK="pre-push"
BYPASS="git push --no-verify"   # native-git one-off skip of all hooks
_check_on() {
    local v; v=$(git config --bool "dotconfigs.$HOOK.$1" 2>/dev/null)
    [[ "$v" != false ]]
}
_block() {
    echo "❌ BLOCKED by $HOOK/$1: $2" >&2
    [[ -n "$BYPASS" ]] && echo "   skip all hooks once (native git): $BYPASS" >&2
    echo "   disable this check (dotconfigs): set git.hooks.$HOOK.checks.$1=false in ~/.dotconfigs/deploy.json, then: dotconfigs deploy" >&2
    exit 1
}

# --- force-push-guard: block force-push to protected branches ---
if _check_on force-push-guard; then
    while read -r local_ref local_oid remote_ref remote_oid; do
        if [[ "$remote_ref" =~ refs/heads/(main|master) ]]; then
            if [[ "$remote_oid" != "0000000000000000000000000000000000000000" ]] && \
               [[ "$local_oid" != "0000000000000000000000000000000000000000" ]] && \
               ! git merge-base --is-ancestor "$remote_oid" "$local_oid" 2>/dev/null; then
                _block force-push-guard "force-push to main/master is blocked"
            fi
        fi
    done
fi

# --- ruff: fast lint + format check (tests and types run in CI) ---
if _check_on ruff && command -v ruff &> /dev/null; then
    echo "🔒 Validating push..."
    # Auto-detect lint paths (prefer src/ layout, fall back to .)
    if [ -d "src" ]; then
        LINT_PATHS="src/"
        [ -d "tests" ] && LINT_PATHS="$LINT_PATHS tests/"
    else
        LINT_PATHS="."
    fi
    echo "  → Checking lint..."
    ruff check $LINT_PATHS || _block ruff "lint failed"
    echo "  → Checking format..."
    ruff format --check $LINT_PATHS || _block ruff "format check failed"
    echo "✅ All checks passed"
fi

# Project-specific hook
[ -x .git/hooks/pre-push.local ] && .git/hooks/pre-push.local

exit 0
