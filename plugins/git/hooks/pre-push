#!/usr/bin/env bash
# === METADATA ===
# NAME: pre-push
# TYPE: git-hook
# PLUGIN: git
# DESCRIPTION: Force-push protection and fast lint/format check (tests + types run in CI)
# CONFIGURABLE: none
# ================

set -e

# Read ref info and block force push to protected branches
while read local_ref local_oid remote_ref remote_oid; do
    if [[ "$remote_ref" =~ refs/heads/(main|master) ]]; then
        if [[ "$remote_oid" != "0000000000000000000000000000000000000000" ]] && \
           [[ "$local_oid" != "0000000000000000000000000000000000000000" ]] && \
           ! git merge-base --is-ancestor "$remote_oid" "$local_oid" 2>/dev/null; then
            echo "❌ ERROR: Force push to main/master is blocked"
            exit 1
        fi
    fi
done

# Fast lint + format check (~2s) — tests and types run in CI
echo "🔒 Validating push..."

if command -v ruff &> /dev/null; then
    # Auto-detect lint paths (prefer src/ layout, fall back to .)
    if [ -d "src" ]; then
        LINT_PATHS="src/"
        [ -d "tests" ] && LINT_PATHS="$LINT_PATHS tests/"
    else
        LINT_PATHS="."
    fi

    echo "  → Checking lint..."
    ruff check $LINT_PATHS || { echo "❌ Lint failed"; exit 1; }
    echo "  → Checking format..."
    ruff format --check $LINT_PATHS || { echo "❌ Format check failed"; exit 1; }
fi

echo "✅ All checks passed"

# Project-specific hook
[ -x .git/hooks/pre-push.local ] && .git/hooks/pre-push.local

exit 0
