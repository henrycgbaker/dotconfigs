#!/usr/bin/env bash
# === METADATA ===
# NAME: pre-commit
# TYPE: git-hook
# PLUGIN: git
# DESCRIPTION: Pre-commit — identity check, secrets scan, block main commits, Ruff format+lint on staged files
# CONFIGURABLE: none
# ================

set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# ALWAYS: Identity check (~10ms)
EXPECTED_NAME="henrycgbaker"
EXPECTED_EMAIL="henry.c.g.baker@gmail.com"
ACTUAL_NAME=$(git config user.name)
ACTUAL_EMAIL=$(git config user.email)

if [ "$ACTUAL_NAME" != "$EXPECTED_NAME" ] || [ "$ACTUAL_EMAIL" != "$EXPECTED_EMAIL" ]; then
    echo "❌ ERROR: Git identity mismatch"
    echo "Expected: $EXPECTED_NAME <$EXPECTED_EMAIL>"
    echo "Actual: $ACTUAL_NAME <$ACTUAL_EMAIL>"
    exit 1
fi

# ALWAYS: Block .planning/ files from being committed
# .planning/ lives on disk only, excluded via .git/info/exclude.
# This guard catches accidental staging (e.g. git add -A).
PLANNING_FILES=$(git diff --cached --name-only | grep '^\.planning/' || true)
if [ -n "$PLANNING_FILES" ]; then
    echo "ERROR: .planning/ files must not be committed."
    echo "They are excluded from version control via .git/info/exclude."
    echo "Remove them with: git reset HEAD .planning/"
    echo ""
    echo "Blocked files:"
    echo "$PLANNING_FILES" | sed 's/^/  /'
    exit 1
fi

# ALWAYS: Block direct main commits
if [[ "$BRANCH" == "main" ]] || [[ "$BRANCH" == "master" ]]; then
    echo "❌ ERROR: Direct commits to $BRANCH are blocked. Use a feature branch."
    exit 1
fi

# ALWAYS: Secrets scan (gitleaks if available, inline regex fallback)
if command -v gitleaks &> /dev/null; then
    gitleaks protect --staged --no-banner -v 2>/dev/null || {
        echo "❌ ERROR: gitleaks detected secrets in staged changes"
        exit 1
    }
else
    STAGED_CONTENT=$(git diff --cached --diff-filter=ACM -U0 2>/dev/null | sed -n '/^+[^+]/p' || true)
    if [ -n "$STAGED_CONTENT" ]; then
        for pattern in 'AKIA[0-9A-Z]{16}' '(sk|pk)_(test|live)_[a-zA-Z0-9]{24,}' 'AIza[0-9A-Za-z_-]{35}'; do
            if echo "$STAGED_CONTENT" | grep -qE -- "$pattern"; then
                echo "❌ ERROR: Possible secret detected in staged changes"
                echo "Pattern: $pattern"
                exit 1
            fi
        done
        _pk="-----""BEGIN"
        if echo "$STAGED_CONTENT" | grep -q -- "$_pk"; then
            echo "❌ ERROR: Possible private key detected in staged changes"
            exit 1
        fi
    fi
fi

# ALL BRANCHES: Ruff format + lint on staged .py files (~1s)
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$STAGED_PY" ] && command -v ruff &> /dev/null; then
    for file in $STAGED_PY; do
        if [ -f "$file" ]; then
            ruff format "$file"
            ruff check --fix "$file" || true
            git add "$file"
        fi
    done
fi

# CONDITIONAL: Conflict-resurrection check (only during merge or rebase)
# Long-running branch resolutions can silently resurrect deleted code or
# undo a fix that landed on main. Compare the net effect against main and
# warn (do not block - some resurrections are intentional).
# Cannot fire on GH UI merges (those run server-side); see /preflight-merge.
if [ -e .git/MERGE_HEAD ] || [ -d .git/rebase-merge ] || [ -d .git/rebase-apply ]; then
    if git rev-parse --verify origin/main >/dev/null 2>&1; then
        MERGE_BASE=$(git merge-base origin/main HEAD 2>/dev/null || echo "")
        if [ -n "$MERGE_BASE" ]; then
            STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
            for f in $STAGED; do
                if git diff --quiet "$MERGE_BASE"..origin/main -- "$f" 2>/dev/null; then
                    continue
                fi
                MAIN_DELTA=$(git diff --shortstat "$MERGE_BASE"..origin/main -- "$f" 2>/dev/null)
                NET_DELTA=$(git diff --shortstat origin/main -- "$f" 2>/dev/null)
                if [ -n "$MAIN_DELTA" ] && [ -n "$NET_DELTA" ]; then
                    echo "⚠  resurrection-check: $f overlaps main changes since merge-base"
                    echo "    main added/removed since merge-base: $MAIN_DELTA"
                    echo "    your branch's net diff vs main:      $NET_DELTA"
                    echo "    Inspect: git diff origin/main -- '$f'"
                fi
            done
            if [ -n "$STAGED" ]; then
                echo "⚠  resurrection-check complete. Warnings above are advisory."
                echo "   Some resurrections are intentional (revert PRs); proceed if expected."
                echo "   For full per-hunk inspection: /check-resolution"
            fi
        fi
    fi
fi

# Project-specific hook
[ -x .git/hooks/pre-commit.local ] && .git/hooks/pre-commit.local

exit 0
