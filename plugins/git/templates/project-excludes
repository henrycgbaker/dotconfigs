# Project-local git excludes — managed by dotconfigs
# Deployed to .git/info/exclude (not tracked, per-machine)
#
# Use for patterns that are personal or machine-specific.
# Unlike .gitignore, this file is NOT tracked in the repo.
# Global patterns (OS, editor, language) belong in ~/.config/git/ignore.

# dotconfigs project config (machine-specific)
.dotconfigs/

# Claude Code (local settings, memory, agents)
.claude/
CLAUDE.md
CLAUDE.local.md

# Editor / IDE (if not in global excludes)
.idea/
.vscode/
*.code-workspace

# Local environment
.env
.env.local
.env.*.local

# GSD planning artifacts
.planning/

# Claude Code sandbox artifacts (created on session init with $HOME=workspace)
# Shell dotfiles
.bash_profile
.bashrc
.gitconfig
.gitmodules
.profile
.ripgreprc
.zprofile
.zshrc
# Git-internal placeholders. Root-anchored (leading /) so they only match the
# sandbox copies at the repo root - bare names would also ignore any nested
# dir/file of the same name (e.g. plugins/*/hooks/, a config/ subdir).
/HEAD
/config
/hooks
/objects
/refs
# Other sandbox copies
.mcp.json
