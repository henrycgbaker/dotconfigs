# Git configuration — managed by dotconfigs
# Symlinked to ~/.dotconfigs/gitconfig-base, included from ~/.gitconfig
# Machine-local config (credentials, overrides) goes in ~/.gitconfig directly.

[user]
	name = henrycgbaker
	email = henry.c.g.baker@gmail.com

[core]
	pager = cat
	excludesFile = ~/.config/git/ignore

[init]
	defaultBranch = main
	# NOTE: init.templateDir (which seeds new repos with the git hooks) is NOT set
	# here. global-deploy manages it imperatively in ~/.gitconfig, coupled to the
	# git `hooks` module: it is set when `hooks` is selected and unset when you
	# exclude it from .dotconfigs/global.json. That keeps "turn off git seeding"
	# a one-line edit with no orphan config left behind.

[pull]
	rebase = true

[fetch]
	prune = true

[push]
	default = simple

[alias]
	unstage = reset HEAD --
	last = log -1 HEAD
	lg = log --oneline --graph --all --decorate
	amend = commit --amend --no-edit
	undo = reset HEAD~1 --mixed
	wip = commit -am WIP
