# Git configuration — managed by dotconfigs
# Symlinked to ~/.dotconfigs/gitconfig-base, included from ~/.gitconfig
# Machine-local config (credentials, overrides) goes in ~/.gitconfig directly.

[user]
	name = henrycgbaker
	email = henry.c.g.baker@gmail.com

[core]
	pager = cat
	excludesFile = ~/.config/git/ignore

[init]
	defaultBranch = main
	# Seed every new `git init` / `git clone` with the dotconfigs git hooks.
	# Hooks live in ~/.dotconfigs/git-template/hooks (symlinks to the plugin
	# source); git copies them (preserving the symlinks) into each new repo's
	# .git/hooks, so hooks are personal/untracked and auto-update with the repo.
	# Existing repos are covered by `dotconfigs project-deploy` + `dotconfigs status`.
	templateDir = ~/.dotconfigs/git-template

[pull]
	rebase = true

[fetch]
	prune = true

[push]
	default = simple

[alias]
	unstage = reset HEAD --
	last = log -1 HEAD
	lg = log --oneline --graph --all --decorate
	amend = commit --amend --no-edit
	undo = reset HEAD~1 --mixed
	wip = commit -am WIP
