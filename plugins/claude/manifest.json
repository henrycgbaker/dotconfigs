{
  "global": {
    "hooks": {
      "source": "plugins/claude/hooks",
      "target": "~/.claude/hooks",
      "method": "symlink",
      "include": ["block-destructive.sh", "block-ai-pr-attribution.sh", "block-gh-pr-write.sh", "facade-check.sh"]
    },
    "settings": {
      "source": "plugins/claude/settings.json",
      "target": "~/.claude/settings.json",
      "method": "merge"
    },
    "skills": {
      "source": "plugins/claude/skills",
      "target": "~/.claude/skills",
      "method": "symlink",
      "include": ["commit", "squash-merge", "check-resolution", "preflight-merge", "rebase-stacked-prs"]
    },
    "claude-md": {
      "source": "plugins/claude/CLAUDE.md",
      "target": "~/.claude/CLAUDE.md",
      "method": "symlink"
    }
  },
  "project": {
    "hooks": {
      "source": "plugins/claude/hooks",
      "target": ".claude/hooks",
      "method": "symlink",
      "include": ["block-destructive.sh", "block-ai-pr-attribution.sh", "block-gh-pr-write.sh", "facade-check.sh"],
      "exclude": []
    },
    "skills": {
      "source": "plugins/claude/skills",
      "target": ".claude/skills",
      "method": "symlink",
      "include": ["commit", "squash-merge", "check-resolution", "preflight-merge", "rebase-stacked-prs"],
      "exclude": []
    }
  }
}
